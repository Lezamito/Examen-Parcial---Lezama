<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CréditosSeguros</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Parcial.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body { background-color: #f4f6f9; }
        .navbar { background: linear-gradient(90deg, #1a3c6e, #2563eb) !important; }
        .navbar-brand, .navbar .nav-link { color: #fff !important; }
        .navbar .nav-link:hover { color: #93c5fd !important; }
        .footer { background-color: #1a3c6e; color: #cbd5e1; padding: 1rem 0; margin-top: 2rem; }
        .footer a { color: #93c5fd; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm border-bottom box-shadow mb-4">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                    💳 CréditosSeguros
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>
                        @if (User.IsInRole("Analista"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Analista" asp-action="Index">
                                    📋 Panel Analista
                                </a>
                            </li>
                        }
                        @if (User.IsInRole("Cliente"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="SolicitudesCredito" asp-action="MisSolicitudes">
                                    📄 Mis Solicitudes
                                </a>
                            </li>
                            
                            var ultimaMonto = Context.Session.GetString("UltimaSolicitudMonto");
                            var ultimaId = Context.Session.GetString("UltimaSolicitudId");
                            if (!string.IsNullOrEmpty(ultimaMonto) && !string.IsNullOrEmpty(ultimaId))
                            {
                                <li class="nav-item ms-3 border-start ps-3 border-light border-opacity-25">
                                    <a class="nav-link text-warning fw-bold" asp-controller="SolicitudesCredito" asp-action="Detalles" asp-route-id="@ultimaId">
                                        ⏱️ Ver última solicitud @ultimaMonto
                                    </a>
                                </li>
                            }
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer border-top">
        <div class="container text-center">
            &copy; 2026 - CréditosSeguros |
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacidad</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
